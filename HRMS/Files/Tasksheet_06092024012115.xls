    </style>

    <style>
        .btn-signin, .btn-signout {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 30px; /* Set a fixed width */
            height: 30px; /* Set a fixed height */
            padding: 0;
            border: 1px solid red;
            background: transparent;
            box-shadow: none; /* Remove default box-shadow */
            background-size: cover; /* Ensure image covers button */
            background-position: center; /* Center the background image */
            background-repeat: no-repeat; /* Prevent repeating the background image */
            background-color: transparent; /* Ensure no background color is applied */
        }

        .btn-signin {
            background-image: url('../../assets/images/sandclock.png'); /* URL for the Sign In image */
            padding-right: 10px;
        }

        .btn-signout {
            background-image: url('../../assets/images/sandclock.png'); /* URL for the Sign Out image */
            padding-right: 10px;
        }

        .dropdown-menu {
            margin-top: 20px; /* Space between button and dropdown */
        }
    </style>



