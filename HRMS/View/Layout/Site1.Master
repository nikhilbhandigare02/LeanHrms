    <script>
        function showpageAccessSavedMessage(status, remark) {
            Swal.fire({

                icon: status === "Success" ? "success" : "error",
                text: remark,
                timer: 4000,
                showConfirmButton: false
            });
        }
</script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var username = sessionStorage.getItem('username');
            if (username) {
                document.getElementById('usernamePlaceholder').textContent = username;
            }
        });
        /$(document).ready(function () { $('.selectBox').SumoSelect(); });/
        function blockSpecialChar(e) {
            var k;
            document.all ? k = e.keyCode : k = e.which;
            return ((k > 64 && k < 91) || (k > 96 && k < 123) || k == 8 || k == 32 || k == 55 || (k >= 48 && k <= 57) || k == 45);
        }
        function setTwoNumberDecimal(event) {
            this.value = parseFloat(this.value).toFixed(2);
        }

        function getHrmsFileName(path) {
            path = (path || '').toLowerCase().split('?')[0].replace(/\\/g, '/');
            var parts = path.split('/');
            var fileName = parts.length ? parts[parts.length - 1] : path;
            return fileName.replace(/\.aspx$/i, '');
        }

        function isHrmsCurrentMenuLink(href, label) {
            href = (href || '').toLowerCase();
            label = (label || '').toLowerCase();
            if (!href) {
                return false;
            }

            var currentPath = (window.location.pathname || '').toLowerCase();
            var currentQuery = (window.location.search || '').toLowerCase();
            var currentFile = getHrmsFileName(currentPath);
            var hrefPath = href.replace(/^https?:\/\/[^/]+/i, '').split('?')[0].toLowerCase();
            var hrefFile = getHrmsFileName(hrefPath);
            var hrefQuery = href.indexOf('?') >= 0 ? href.substring(href.indexOf('?')).toLowerCase() : '';

            if (label.indexOf('employee registration') >= 0 && currentFile === 'employeeregistration') {
                return true;
            }

            if (label.indexOf('employee list') >= 0 && currentFile === 'viewuser' && currentQuery.indexOf('flow=employee') >= 0) {
                return true;
            }

            if (label.indexOf('remuneration form') >= 0 && currentFile === 'remunerationform') {
                return true;
            }

            if (label.indexOf('remuneration details') >= 0 && currentFile === 'remunerationdetails') {
                return true;
            }

            if (label.indexOf('document') >= 0 && (currentFile === 'useruploaddocuments' || currentFile === 'adduserdocuments' || currentFile === 'viewuserdocuments' || currentFile === 'viewdetailsforprobationperiod')) {
                return true;
            }

            if (label.indexOf('employee leave') >= 0 && (currentFile === 'employeeleavelist' || currentFile === 'employeeleaveview')) {
                return true;
            }

            if (label.indexOf('salary slip') >= 0 && (currentFile === 'salaryslip' || currentFile === 'uploadexcelforsalary' || currentFile === 'addsalaryslipdata')) {
                return true;
            }

            if (label.indexOf('holiday') >= 0 && currentFile === 'holidaylist') {
                return true;
            }

            if (label.indexOf('resignation') >= 0 && currentFile === 'resignationlist') {
                return true;
            }

            if (label.indexOf('user details') >= 0 && (currentFile === 'viewuser' || currentFile === 'adduser' || currentFile === 'addusermain') && currentQuery.indexOf('flow=employee') < 0) {
                return true;
            }

            if (href === 'javascript:void(0);' || href === '#') {
                return false;
            }

            if (currentFile && hrefFile && currentFile === hrefFile) {
                if (currentFile === 'viewuser') {
                    if (currentQuery.indexOf('flow=employee') >= 0) {
                        return hrefQuery.indexOf('flow=employee') >= 0 || label.indexOf('employee list') >= 0;
                    }

                    if (hrefQuery.indexOf('flow=employee') >= 0 || label.indexOf('employee list') >= 0) {
                        return false;
                    }
                }

                if (hrefQuery && hrefQuery.indexOf('flow=employee') >= 0) {
                    return currentQuery.indexOf('flow=employee') >= 0;
                }

                if (href.indexOf('viewuser') >= 0 && label.indexOf('employee list') >= 0) {
                    return currentQuery.indexOf('flow=employee') >= 0;
                }

                return true;
            }

            return false;
        }

        function setupHrmsSidebarClickMemory() {
            document.querySelectorAll('#side-menu a').forEach(function (link) {
                if (link.getAttribute('data-hrms-click-memory') === 'true') {
                    return;
                }

                link.setAttribute('data-hrms-click-memory', 'true');
                link.addEventListener('click', function (event) {
                    if (link.closest('.sub-menu')) {
                        event.stopPropagation();
                    }

                    var href = (link.getAttribute('href') || '').trim();
                    var currentLi = link.closest('li');
                    var directSubMenu = currentLi ? currentLi.querySelector(':scope > .sub-menu') : null;

                    if (directSubMenu && isHrmsSidebarCollapsed()) {
                        event.preventDefault();
                        event.stopPropagation();
                        expandHrmsSidebarForMenu();
                        setHrmsClickedSidebarState(link);
                        openHrmsDirectSubMenu(link);
                        return;
                    }

                    if (!href || href === '#' || href.toLowerCase() === 'javascript:void(0);') {
                        return;
                    }

                    try {
                        sessionStorage.setItem('hrmsActiveSidebarHref', href.toLowerCase());
                        sessionStorage.setItem('hrmsActiveSidebarLabel', (link.textContent || '').trim().toLowerCase());
                    } catch (e) { }

                    setHrmsClickedSidebarState(link);
                });
            });
        }

        function isHrmsSidebarCollapsed() {
            return document.body.classList.contains('vertical-collpsed') ||
                (window.innerWidth <= 992 && !document.body.classList.contains('sidebar-enable'));
        }

        function expandHrmsSidebarForMenu() {
            document.body.classList.remove('vertical-collpsed');

            if (window.innerWidth <= 992) {
                document.body.classList.add('sidebar-enable');
            }
        }

        function openHrmsDirectSubMenu(link) {
            var currentLi = link ? link.closest('li') : null;
            var subMenu = currentLi ? currentLi.querySelector(':scope > .sub-menu') : null;

            if (!currentLi || !subMenu) {
                return;
            }

            currentLi.classList.add('mm-active');
            link.classList.add('active');
            link.setAttribute('aria-expanded', 'true');
            subMenu.classList.add('mm-show');
            subMenu.setAttribute('aria-expanded', 'true');
            subMenu.style.display = 'block';
        }

        function setHrmsClickedSidebarState(link) {
            if (!link || !link.closest('#side-menu')) {
                return;
            }

            document.querySelectorAll('#side-menu a.active').forEach(function (activeLink) {
                activeLink.classList.remove('active');
                activeLink.setAttribute('aria-expanded', 'false');
            });

            document.querySelectorAll('#side-menu li.hrms-pill-active').forEach(function (item) {
                item.classList.remove('hrms-pill-active');
            });

            link.classList.add('active');
            var currentLi = link.closest('li');
            if (currentLi) {
                currentLi.classList.add('hrms-pill-active');
            }

            var parentSubMenu = link.closest('.sub-menu');
            while (parentSubMenu) {
                parentSubMenu.classList.add('mm-show');
                parentSubMenu.setAttribute('aria-expanded', 'true');
                parentSubMenu.style.display = 'block';

                var parentLi = parentSubMenu.parentElement;
                if (parentLi) {
                    parentLi.classList.add('mm-active');
                    var parentLink = parentLi.querySelector(':scope > a');
                    if (parentLink) {
                        parentLink.classList.add('active');
                        parentLink.setAttribute('aria-expanded', 'true');
                    }
                }

                parentSubMenu = parentLi ? parentLi.parentElement.closest('.sub-menu') : null;
            }
        }

        function isHrmsRememberedMenuLink(href, label) {
            try {
                var savedHref = (sessionStorage.getItem('hrmsActiveSidebarHref') || '').toLowerCase();
                var savedLabel = (sessionStorage.getItem('hrmsActiveSidebarLabel') || '').toLowerCase();
                href = (href || '').toLowerCase();
                label = (label || '').toLowerCase();

                if (savedHref && savedHref === href) {
                    return isHrmsCurrentMenuLink(savedHref, label || savedLabel);
                }

                if (savedLabel && savedLabel === label && isHrmsCurrentMenuLink(savedHref, savedLabel)) {
                    return true;
                }
            } catch (e) { }

            return false;
        }

        function highlightHrmsTopLevelLinks() {
            document.querySelectorAll('#side-menu > li > a').forEach(function (link) {
                var item = link.parentElement;
                if (!item || item.querySelector(':scope > .sub-menu')) {
                    return;
                }

                var href = (link.getAttribute('href') || '').toLowerCase();
                var label = (link.textContent || '').trim().toLowerCase();
                if (isHrmsCurrentMenuLink(href, label) || isHrmsRememberedMenuLink(href, label)) {
                    link.classList.add('active');
                } else {
                    link.classList.remove('active');
                }
            });
        }

        function applyHrmsSidebarTimelineMenus() {
            document.querySelectorAll('#side-menu li').forEach(function (item) {
                item.classList.remove('hrms-pill-active');
                item.classList.remove('mm-active');
            });

            document.querySelectorAll('#side-menu a').forEach(function (link) {
                link.classList.remove('active');
                link.setAttribute('aria-expanded', 'false');
            });

            document.querySelectorAll('#side-menu .sub-menu').forEach(function (subMenu) {
                subMenu.classList.remove('mm-show');
                subMenu.setAttribute('aria-expanded', 'false');
                subMenu.style.display = 'none';
            });

            document.querySelectorAll('#side-menu li').forEach(function (item) {
                var subMenu = item.querySelector(':scope > .sub-menu');
                if (subMenu) {
                    item.classList.add('hrms-timeline-menu');
                }

                if (item.parentElement && item.parentElement.classList.contains('sub-menu')) {
                    item.classList.add('hrms-pill-item');
                }
            });

            var activeLinks = [];
            document.querySelectorAll('#side-menu .sub-menu a, #side-menu > li > a').forEach(function (link) {
                var href = (link.getAttribute('href') || '').toLowerCase();
                var label = (link.textContent || '').trim().toLowerCase();
                if (isHrmsCurrentMenuLink(href, label) || isHrmsRememberedMenuLink(href, label)) {
                    activeLinks.push(link);
                }
            });

            activeLinks.forEach(function (link) {
                link.classList.add('active');

                var currentLi = link.closest('li');
                if (currentLi) {
                    currentLi.classList.add('hrms-pill-active');
                }

                var parentSubMenu = link.closest('.sub-menu');
                while (parentSubMenu) {
                    parentSubMenu.classList.add('mm-show');
                    parentSubMenu.setAttribute('aria-expanded', 'true');
                    parentSubMenu.style.display = 'block';

                    var parentLi = parentSubMenu.parentElement;
                    if (parentLi) {
                        parentLi.classList.add('mm-active');
                        var parentLink = parentLi.querySelector(':scope > a');
                        if (parentLink) {
                            parentLink.classList.add('active');
                            parentLink.setAttribute('aria-expanded', 'true');
                        }
                    }

                    parentSubMenu = parentLi ? parentLi.parentElement.closest('.sub-menu') : null;
                }
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            setupHrmsSidebarClickMemory();
            applyHrmsSidebarTimelineMenus();
            highlightHrmsTopLevelLinks();
            document.documentElement.classList.add('hrms-sidebar-ready');

            window.setTimeout(function () {
                applyHrmsSidebarTimelineMenus();
                highlightHrmsTopLevelLinks();
                document.documentElement.classList.add('hrms-sidebar-ready');
            }, 80);
        });
        //$('#txtOccupancy').on('keypress', function (event) {
        //    var regex = new RegExp("[a-zA-Z0-9,.-\\s]+$");
        //    var key = String.fromCharCode(!event.charCode ? event.which : event.charCode);
        //    if (!regex.test(key)) {
        //        event.preventDefault();
        //        return false;
        //    }
        //});
    </script>

    <%--<style>
        .navbar-brand-box {
            display: flex;
            justify-content: space-between; /* Aligns items to both ends */
            align-items: center; /* Centers items vertically */
            margin-left: 0px;
        }

        .logo-background {
            background-color: white;
            display: inline-block;
            padding: 5px 10px; /* Horizontal padding for left and right sides */
            border-radius: 5px; /* Optional: Adds rounded corners */
            box-shadow: 0 0 3px rgba(0, 0, 0, 0.1); /* Optional: Adds a subtle shadow */
        }
    </style>--%>
    <style>
        :root {
            --hrms-primary: #2563EB;
            --hrms-primary-soft: #EFF6FF;
            --hrms-sidebar-text: #526077;
            --hrms-sidebar-strong: #172033;
            --hrms-sidebar-line: #E8EEF7;
        }

        #page-topbar {
            background: #FFFFFF;
            border-bottom: 1px solid #E8EEF7;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
        }

        .navbar-header {
            min-height: 70px;
        }

        .navbar-brand-box {
            align-items: center;
            background: #FFFFFF;
            display: flex;
            height: 70px;
            justify-content: flex-start;
            overflow: hidden;
            padding: 0 20px;
            transition: width .2s ease, padding .2s ease;
            width: 224px;
        }

        .navbar-brand-box .logo {
            align-items: center;
            display: flex;
            height: 48px;
            justify-content: center;
            line-height: normal;
            width: 100%;
        }

        .logo-background {
            align-items: center;
            display: flex;
            height: 44px;
            justify-content: flex-start;
            max-width: 210px;
            padding: 0;
            transition: max-width .2s ease, padding .2s ease;
            width: 100%;
        }

        .logo-background img {
            max-height: 40px;
            max-width: 100%;
            object-fit: contain;
        }

        .logo-sm {
            align-items: center;
            display: none;
            justify-content: center;
            width: 44px;
        }

        .logo-sm img {
            max-height: 24px;
            max-width: 30px;
            object-fit: contain;
        }

        .sidebar-toggle-btn {
            align-items: center;
            background: #F8FAFF;
            border: 1px solid #DCE8FF;
            border-radius: 10px;
            color: var(--hrms-primary);
            display: inline-flex;
            height: 38px;
            justify-content: center;
            margin-left: 2px;
            margin-right: 10px;
            margin-top: 6px;
            padding: 0 !important;
            transition: background-color .18s ease, border-color .18s ease, color .18s ease, box-shadow .18s ease, transform .18s ease;
            width: 38px;
        }

        .sidebar-toggle-btn:hover,
        .sidebar-toggle-btn:focus {
            background: var(--hrms-primary);
            border-color: var(--hrms-primary);
            box-shadow: 0 10px 20px rgba(37, 99, 235, 0.18);
            color: #FFFFFF;
            transform: translateY(-1px);
        }

        .sidebar-toggle-btn i {
            font-size: 15px;
            line-height: 1;
        }

        body.vertical-collpsed .navbar-brand-box {
            padding: 0 !important;
            width: 0 !important;
        }

        body.vertical-collpsed .navbar-brand-box .logo,
        body.vertical-collpsed .navbar-brand-box .logo-lg,
        body.vertical-collpsed .navbar-brand-box .logo-sm {
            display: none;
        }

        body.vertical-collpsed .sidebar-toggle-btn {
            margin-left: 16px;
        }

        body.vertical-collpsed .vertical-menu {
            bottom: 0;
            overflow: hidden;
            position: fixed !important;
            top: 70px;
            width: 70px !important;
            z-index: 1001;
        }

        body.vertical-collpsed #sidebar-menu {
            padding: 18px 8px 24px;
            overflow: hidden;
        }

        body.vertical-collpsed #sidebar-menu .menu-title,
        body.vertical-collpsed #sidebar-menu .menu-title:after,
        body.vertical-collpsed #sidebar-menu ul li a span,
        body.vertical-collpsed #sidebar-menu .has-arrow:after,
        body.vertical-collpsed #sidebar-menu .sub-menu {
            display: none !important;
        }

        body.vertical-collpsed #sidebar-menu ul li a {
            align-items: center;
            border-radius: 12px;
            display: flex;
            gap: 0;
            height: 48px;
            justify-content: center;
            margin: 8px 0;
            min-height: 48px;
            padding: 0 !important;
            transform: none !important;
            width: 48px;
        }

        body.vertical-collpsed #sidebar-menu ul li a i {
            margin: 0;
            min-width: 0;
        }

        .vertical-menu {
            background: #FFFFFF;
            border-right: 1px solid var(--hrms-sidebar-line);
            box-shadow: 12px 0 30px rgba(15, 23, 42, 0.04);
        }

        #sidebar-menu {
            padding: 18px 12px 24px;
        }

        #sidebar-menu .menu-title {
            color: var(--hrms-primary) !important;
            font-size: 12px;
            font-weight: 900;
            letter-spacing: 0;
            padding: 10px 12px 14px !important;
            text-transform: uppercase;
            position: relative;
        }

        #sidebar-menu .menu-title:after {
            content: "";
            display: block;
            width: 34px;
            height: 3px;
            border-radius: 999px;
            background: var(--hrms-primary);
            margin-top: 7px;
            opacity: .9;
        }

        #sidebar-menu ul li a {
            min-height: 44px;
            border-radius: 12px;
            color: var(--hrms-sidebar-text) !important;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            font-weight: 700;
            margin: 3px 0;
            padding: 10px 12px !important;
            position: relative;
            transition: background-color .18s ease, color .18s ease, transform .18s ease, box-shadow .18s ease;
        }

        #sidebar-menu ul li a i {
            color: #7A8493;
            font-size: 18px;
            min-width: 20px;
            text-align: center;
            transition: color .18s ease, transform .18s ease;
        }

        #sidebar-menu ul li a:hover,
        #sidebar-menu ul li.mm-active > a,
        #sidebar-menu ul li a.active {
            background: var(--hrms-primary-soft);
            color: var(--hrms-primary) !important;
            box-shadow: inset 3px 0 0 var(--hrms-primary);
            transform: translateX(2px);
        }

        #sidebar-menu ul li a:hover i,
        #sidebar-menu ul li.mm-active > a i,
        #sidebar-menu ul li a.active i {
            color: var(--hrms-primary);
            transform: scale(1.04);
        }

        #sidebar-menu .has-arrow:after {
            border-color: currentColor;
            right: 14px;
            transition: transform .18s ease;
        }

        #sidebar-menu li.mm-active > .has-arrow:after {
            transform: rotate(135deg);
        }

        #sidebar-menu .sub-menu {
            margin: 4px 0 8px 21px;
            padding-left: 13px !important;
            border-left: 1px dashed #D8E2F1;
            opacity: 1;
            transform: translateY(0);
            transition: opacity .14s ease, transform .14s ease;
        }

        html:not(.hrms-sidebar-ready) #sidebar-menu .sub-menu,
        html:not(.hrms-sidebar-ready) #sidebar-menu ul li a {
            transition: none !important;
        }

        #sidebar-menu .sub-menu:not(.mm-show) {
            display: none !important;
            opacity: 0;
            transform: translateY(-3px);
        }

        #sidebar-menu .sub-menu.mm-show {
            display: block !important;
            opacity: 1;
            transform: translateY(0);
        }

        #sidebar-menu .sub-menu li a {
            min-height: 36px;
            border-radius: 10px;
            color: #66758A !important;
            font-size: 13px;
            font-weight: 650;
            margin: 2px 0;
            padding: 8px 12px !important;
        }

        #sidebar-menu .sub-menu li a:hover,
        #sidebar-menu .sub-menu li a.active {
            background: #F4F8FF;
            color: var(--hrms-primary) !important;
            box-shadow: none;
            transform: translateX(2px);
        }

        #sidebar-menu li.hrms-onboarding-menu > a {
            background: #F1F5FF;
            color: var(--hrms-primary) !important;
            box-shadow: 0 8px 18px rgba(37, 99, 235, 0.08);
        }

        #sidebar-menu li.hrms-onboarding-menu > a i {
            color: var(--hrms-primary);
        }

        #sidebar-menu li.hrms-onboarding-menu > .sub-menu {
            border-left: 0;
            margin: 0;
            padding-left: 0 !important;
        }

        #sidebar-menu li.hrms-onboarding-menu > .sub-menu.mm-show {
            border-left: 2px solid #D7E2F4;
            margin: 6px 0 14px 21px;
            padding: 4px 0 6px 16px !important;
            position: relative;
        }

        #sidebar-menu li.hrms-onboarding-menu > .sub-menu li.hrms-pill-item {
            position: relative;
        }

        #sidebar-menu li.hrms-onboarding-menu > .sub-menu li.hrms-pill-item:before {
            display: none;
        }

        #sidebar-menu li.hrms-onboarding-menu > .sub-menu.mm-show li.hrms-pill-item:before {
            background: #FFFFFF;
            border: 2px solid #B7C6D9;
            border-radius: 50%;
            box-shadow: 0 0 0 3px #FFFFFF;
            content: "";
            display: none;
            height: 9px;
            left: -21px;
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 9px;
            z-index: 1;
        }

        #sidebar-menu li.hrms-onboarding-menu > .sub-menu li.hrms-pill-item a {
            border-radius: 13px;
            font-size: 13px;
            line-height: 1.2;
            margin: 2px 0;
            min-height: 40px;
            padding: 10px 14px !important;
            white-space: nowrap;
        }

        #sidebar-menu li.hrms-onboarding-menu > .sub-menu.mm-show li.hrms-pill-item a {
            margin: 6px 0;
        }

        #sidebar-menu li.hrms-onboarding-menu > .sub-menu.mm-show li.hrms-pill-item.hrms-pill-active a,
        #sidebar-menu li.hrms-onboarding-menu > .sub-menu.mm-show li.hrms-pill-item a.active {
            background: linear-gradient(90deg, #EEF4FF 0%, #F6F9FF 100%);
            color: var(--hrms-primary) !important;
            font-weight: 900;
            box-shadow: 0 8px 18px rgba(37, 99, 235, 0.08);
            transform: none;
        }

        #sidebar-menu li.hrms-timeline-menu > .sub-menu {
            border-left: 0;
            margin: 0;
            padding-left: 0 !important;
        }

        #sidebar-menu li.hrms-timeline-menu > .sub-menu.mm-show {
            border-left: 2px solid #D7E2F4;
            margin: 6px 0 14px 21px;
            padding: 4px 0 6px 16px !important;
            position: relative;
        }

        #sidebar-menu li.hrms-timeline-menu > .sub-menu li.hrms-pill-item {
            position: relative;
        }

        #sidebar-menu li.hrms-timeline-menu > .sub-menu li.hrms-pill-item a {
            border-radius: 13px;
            font-size: 13px;
            line-height: 1.2;
            margin: 2px 0;
            min-height: 40px;
            padding: 10px 14px !important;
            white-space: nowrap;
        }

        #sidebar-menu li.hrms-timeline-menu > .sub-menu.mm-show li.hrms-pill-item a {
            margin: 6px 0;
        }

        #sidebar-menu li.hrms-timeline-menu > .sub-menu.mm-show li.hrms-pill-item.hrms-pill-active a,
        #sidebar-menu li.hrms-timeline-menu > .sub-menu.mm-show li.hrms-pill-item a.active {
            background: linear-gradient(90deg, #EEF4FF 0%, #F6F9FF 100%);
            color: var(--hrms-primary) !important;
            font-weight: 900;
            box-shadow: 0 8px 18px rgba(37, 99, 235, 0.08);
            transform: none;
        }

        #sidebar-menu ul li a span {
            flex: 1 1 auto;
            line-height: 1.25;
            min-width: 0;
            white-space: nowrap;
        }

        body[data-sidebar="light"] .mm-active {
            color: var(--hrms-primary) !important;
        }

        @media (max-width: 992px) {
            #page-topbar {
                background: #FFFFFF;
                border-bottom-color: #E8EEF7;
                box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
