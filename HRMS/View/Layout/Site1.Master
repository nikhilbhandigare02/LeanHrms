            .navbar-brand-box .logo-background {
                display: flex !important;
            }

            .logo span.logo-sm,
            .navbar-brand-box .logo-sm {
                display: none !important;
            }

            .logo-background {
                height: 40px;
                max-width: 190px;
            }

            .logo-background img {
                max-height: 30px;
            }

            .sidebar-toggle-btn {
                background: #F8FAFF;
                border-color: #DCE8FF;
                border-radius: 8px;
                box-shadow: none;
                color: var(--hrms-primary);
                flex: 0 0 32px;
                height: 32px;
                margin: 0 12px 0 0;
                order: 1;
                width: 32px;
            }

            .sidebar-toggle-btn:hover,
            .sidebar-toggle-btn:focus {
                background: var(--hrms-primary);
                border-color: var(--hrms-primary);
                box-shadow: 0 10px 20px rgba(37, 99, 235, 0.18);
                color: #FFFFFF;
                transform: translateY(-1px);
            }

            body.sidebar-enable .navbar-brand-box {
                flex: 1 1 auto;
                padding: 0 !important;
                width: auto !important;
            }

            body.sidebar-enable .sidebar-toggle-btn {
                margin-left: 0;
            }

            body.sidebar-enable .vertical-menu {
                width: 300px !important;
            }

            body.sidebar-enable #sidebar-menu {
                padding-left: 14px;
                padding-right: 14px;
            }

            body.sidebar-enable #sidebar-menu .menu-title {
                display: block !important;
            }

            body.sidebar-enable #sidebar-menu .menu-title:after {
                display: block !important;
            }

            body.sidebar-enable #sidebar-menu ul li a {
                gap: 12px;
                padding-left: 14px !important;
                padding-right: 18px !important;
                width: auto;
            }

            body.sidebar-enable #sidebar-menu ul li a span {
                display: inline-block !important;
                white-space: normal;
                word-break: normal;
            }

            body.sidebar-enable #sidebar-menu .has-arrow:after {
                display: block !important;
                right: 12px;
            }

            body.sidebar-enable #sidebar-menu .sub-menu.mm-show {
                display: block !important;
            }

            body:not(.sidebar-enable) .vertical-menu {
                bottom: 0;
                overflow: hidden;
                position: fixed !important;
                top: 70px;
                width: 70px !important;
                z-index: 1001;
            }

            body:not(.sidebar-enable) #sidebar-menu {
                padding: 18px 8px 24px;
                overflow: hidden;
            }

            body:not(.sidebar-enable) #sidebar-menu .menu-title,
            body:not(.sidebar-enable) #sidebar-menu .menu-title:after,
            body:not(.sidebar-enable) #sidebar-menu ul li a span,
            body:not(.sidebar-enable) #sidebar-menu .has-arrow:after,
            body:not(.sidebar-enable) #sidebar-menu .sub-menu {
                display: none !important;
            }

            body:not(.sidebar-enable) #sidebar-menu ul li a {
                align-items: center;
                border-radius: 12px;
                display: flex;
                gap: 0;
                height: 48px;
                justify-content: center;
                margin: 8px 0;
                min-height: 48px;
                padding: 0 !important;
                transform: none !important;
                width: 48px;
            }

            body:not(.sidebar-enable) #sidebar-menu ul li a i {
                margin: 0;
                min-width: 0;
            }
        }
    </style>


